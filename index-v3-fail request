// ═══════ 6. PICK TOPIC ═══════
function pickTopic(){
  const s=+$('r-spot').value,f=+$('r-fut').value,n=+$('r-narr').value,a=+$('r-air').value;
  const o=Math.max(0,100-s-f-n-a),r=Math.random()*100;
  if(r<a&&S.airdrops.length){const hot=S.airdrops.filter(x=>x.hot);return{type:'airdrop',data:(hot.length?hot:S.airdrops)[Math.floor(Math.random()*Math.min((hot.length||S.airdrops.length),8))]};}
  if(r<a+n&&S.narratives.length){const hot=S.narratives.filter(x=>x.heat>=4);return{type:'narrative',data:(hot.length?hot:S.narratives)[Math.floor(Math.random()*Math.min((hot.length||S.narratives.length),8))]};}
  if(r<a+n+o&&S.coins.length){const pool=S.coins.filter(c=>c.type==='off-chain');return{type:'offchain',data:(pool.length?pool:S.coins.slice(0,10))[Math.floor(Math.random()*Math.min(pool.length||10,8))]};}
  if(S.coins.length){
    const pool=S.coins.filter(c=>c.type===(r<a+n+o+f?'futures':'spot'));
    const drama=pool.filter(c=>c.drama);
    return{type:r<a+n+o+f?'futures':'spot',data:(drama.length?drama:pool)[Math.floor(Math.random()*Math.min((drama.length||pool.length),12))]};
  }
  return{type:'narrative',data:{name:'Bitcoin Ecosystem',description:'BTC market structure',coins:['BTC'],heat:5,catalyst:S.intel.drama||'Price action'}};
}

