<script>
// ═══════ STATE ═══════
const S={running:false,timer:null,cdt:null,nextRun:null,posted:0,coins:[],cf:'all',
  intel:{funding:'',whale:'',drama:'',dramaCoins:[],futuresList:[]},
  narratives:[],airdrops:[]};

// ═══════ HELPERS ═══════
const $=id=>document.getElementById(id);
const esc=s=>String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
const ts=()=>new Date().toLocaleTimeString('vi-VN');
const fmtP=p=>{if(!p)return'0';if(p>1000)return p.toLocaleString('en-US',{maximumFractionDigits:0});if(p>1)return p.toFixed(2);return p.toFixed(6);};
const fmtV=v=>{if(!v)return'0';if(v>1e9)return(v/1e9).toFixed(2)+'B';if(v>1e6)return(v/1e6).toFixed(1)+'M';if(v>1e3)return(v/1e3).toFixed(0)+'K';return String(v);};

function log(type,msg){
  const w=$('log-w'),t=ts();
  const cls={ok:'log-ok',err:'log-err',info:'log-info',warn:'log-warn'}[type]||'log-info';
  const d=document.createElement('div');d.className='log-line';
  d.innerHTML=`<span class="log-ts">${t}</span><span class="${cls}">${esc(msg)}</span>`;
  w.appendChild(d);w.scrollTop=w.scrollHeight;
}

function st(name){
  const names=['market','intel','narratives','airdrops','preview','log','history'];
  document.querySelectorAll('.tab').forEach((t,i)=>t.classList.toggle('active',names[i]===name));
