// ═══════ OPENAI CALL ═══════
async function callOAI({system,user,webSearch=false,json=false}){
  const key=$('oai-key').value.trim();
  if(!key) throw new Error('Chưa nhập OpenAI API key');
  const body={
    model:'gpt-4o',max_tokens:1500,temperature:0.7,
    messages:[{role:'system',content:system},{role:'user',content:user}],
  };
  if(webSearch) body.tools=[{type:'web_search_preview'}],body.tool_choice='auto';
  if(json) body.response_format={type:'json_object'};
  const res=await fetch('https://api.openai.com/v1/chat/completions',{
    method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+key},
    body:JSON.stringify(body)
  });
  if(!res.ok){const e=await res.json();throw new Error(e.error?.message||'OpenAI error');}
  const data=await res.json();
  const msg=data.choices[0].message;
  if(typeof msg.content==='string') return msg.content.trim();
  if(Array.isArray(msg.content)) return msg.content.filter(b=>b.type==='text').map(b=>b.text).join('\n').trim();
  return '';
}

// ═══════ 1. MARKET — CoinGecko real-time ═══════
async function fetchMkt(){
  $('mkt-ic').className='spin';$('btn-mkt').disabled=true;
  log('info','Fetching CoinGecko top 100 + trending...');
  try{
    const bl=($('blist').value||'').split(',').map(s=>s.trim().toUpperCase()).filter(Boolean);
    const [r1,r2]=await Promise.all([
      fetch('https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&order=market_cap_desc&per_page=100&page=1&sparkline=false&price_change_percentage=24h'),
      fetch('https://api.coingecko.com/api/v3/search/trending')
    ]);
    const d1=await r1.json(),d2=await r2.json();
    const trending=new Set((d2.coins||[]).map(c=>c.item.symbol.toUpperCase()));
    const futSet=S.intel.futuresList.length?new Set(S.intel.futuresList):new Set(['BTC','ETH','BNB','SOL','ADA','XRP','DOGE','AVAX','LINK','DOT','MATIC','UNI','ATOM','LTC','TRX','NEAR','OP','ARB','APT','SUI','INJ','WLD','JUP','WIF','BONK','STRK','TIA']);
    S.coins=[];
    d1.forEach(c=>{
      const sym=c.symbol.toUpperCase();
      if(bl.includes(sym))return;
      const chg=Math.abs(c.price_change_percentage_24h||0);
      const isTrend=trending.has(sym);
      const ai=S.intel.dramaCoins.find(d=>d.symbol===sym);
      S.coins.push({
        symbol:sym,name:c.name,price:c.current_price,change:c.price_change_percentage_24h,
        volume:c.total_volume,mcap:c.market_cap,
        type:futSet.has(sym)?(Math.random()>.5?'futures':'spot'):'spot',
        drama:chg>5||isTrend||!!ai,
        dramaLabel:ai?.signal||(isTrend?'🔥 Trending':(chg>8?'🚀 Pump':(chg>5?'⚡ Move':'—'))),
        narrative:ai?.narrative||'',isGem:c.market_cap<100e6&&c.market_cap>1e6,
      });
    });
    $('m-coins').textContent=S.coins.length;
    $('mkt-ts').textContent='Updated '+ts();
    $('m-scan').textContent=ts();
    log('ok',`Loaded ${S.coins.length} coins. ${trending.size} trending on CoinGecko.`);
    renderMkt();
  }catch(e){log('err','Market error: '+e.message);}
  $('mkt-ic').className='';$('mkt-ic').textContent='⟳';$('btn-mkt').disabled=false;
}

function renderMkt(){
  let data=S.coins;
  if(S.cf==='drama') data=data.filter(c=>c.drama);
  else if(S.cf==='futures') data=data.filter(c=>c.type==='futures');
  else if(S.cf==='off') data=data.filter(c=>c.type==='off-chain');
  else if(S.cf==='gem') data=data.filter(c=>c.isGem);
  const tbody=$('mkt-body');
  if(!data.length){tbody.innerHTML='<tr><td colspan="7" style="text-align:center;color:var(--text3);padding:2rem;font-family:var(--mono)">Không có dữ liệu</td></tr>';return;}
  tbody.innerHTML=data.slice(0,60).map(c=>{
    const chg=(c.change||0).toFixed(2),cls=parseFloat(chg)>=0?'up':'down',sign=parseFloat(chg)>=0?'+':'';
    const tB=c.type==='off-chain'?'<span class="badge off">OFF</span>':c.type==='futures'?'<span class="badge futures">PERP</span>':'<span class="badge spot">SPOT</span>';
    const gB=c.isGem?'<span class="badge gem" style="font-size:8px">GEM</span>':'';
    const nB=c.narrative?`<span class="badge narr" style="font-size:8px">${esc(c.narrative.substring(0,14))}</span>`:'';
    const dB=c.drama?'<span class="badge drama" style="font-size:8px">DRAMA</span>':'';
    return `<tr><td><span class="cn">$${c.symbol}</span> <span class="ct">${esc(c.name.substring(0,12))}</span></td><td>${tB}${gB}</td><td style="font-family:var(--mono)">$${fmtP(c.price)}</td><td class="${cls}" style="font-family:var(--mono);font-weight:600">${sign}${chg}%</td><td style="font-family:var(--mono);color:var(--text2)">$${fmtV(c.volume)}</td><td>${nB}</td><td>${dB}<span style="font-size:10px;color:var(--text2)">${esc(c.dramaLabel||'')}</span></td></tr>`;
  }).join('');
}
function flt(f){S.cf=f;renderMkt();}

