function buildPrompt(topic){
  const lang=$('lang').value,plen=$('plen').value,tone=$('tone').value,custom=$('custom').value.trim();
  const langMap={vi:'Vietnamese',en:'English',bilingual:'Vietnamese first, English below each paragraph'};
  const lenMap={short:'100–160 words',medium:'260–330 words',long:'460–560 words'};
  const toneMap={
    drama:'Dramatic, FOMO-inducing, urgent. Open with a killer hook. Crypto Twitter energy.',
    analytical:'Data-driven, analytical. Lead with a key number/anomaly. Professional trader voice.',
    educational:'Clear, educational, explain WHY with analogies. Good for all levels.',
    alpha:'Alpha-hunter. "Not many watching this." On-chain forward-looking signals.',
    thread:'Thread format: 1/ 2/ 3/ — each tweet self-contained and punchy.',
    degen:'Degen CT voice. Casual, meme-aware but genuinely informative.',
  };
  const extras=[];
  if($('i-oc').checked) extras.push('Weave in on-chain signals from the live data provided (whale moves, exchange flows, TVL)');
  if($('i-sent').checked) extras.push('Include funding rate/sentiment context from the live data');
  if($('i-ta').checked) extras.push('Add brief TA context — key levels to watch, no specific price targets');
  if($('i-mac').checked) extras.push('Connect briefly to macro (DXY, BTC dominance, risk-on/off)');
  if($('i-risk').checked) extras.push('Close with natural risk disclaimer (DYOR, not financial advice)');

  // Live context injected into every post
  const liveCtx=[
    S.intel.drama?`CURRENT DRAMA/NEWS: ${S.intel.drama}`:'',
    S.intel.funding?`FUNDING/OI: ${S.intel.funding.substring(0,280)}`:'',
    S.intel.whale?`WHALE ACTIVITY: ${S.intel.whale.substring(0,280)}`:'',
    S.narratives.length?`HOT NARRATIVES NOW: ${S.narratives.slice(0,3).map(n=>n.name+' (catalyst: '+n.catalyst+')').join('; ')}`:'',
  ].filter(Boolean).join('\n');

  let topicCtx='';
  if(topic.type==='airdrop'){
    const a=topic.data||{};
    topicCtx=`PROJECT: ${a.name} ($${a.symbol||'?'})
Stage: ${a.stage} | Hot: ${a.hot?'YES':'moderate'}
What it is: ${a.description}
How to participate: ${a.tasks}
Narrative: ${a.narrative}${a.deadline?'\nDeadline: '+a.deadline:''}
Write: WHY it matters NOW, how to qualify, honest risk vs reward. Be specific.`;
  } else if(topic.type==='narrative'){
    const n=topic.data||{};
    topicCtx=`NARRATIVE: ${n.name}
What's happening: ${n.description}
Key catalyst TODAY: ${n.catalyst||'momentum building'}
Coins in play: ${(n.coins||[]).map(c=>'$'+c).join(', ')}
Risk: ${n.risk||'rotation risk'}
Write: why moving NOW, best positioned coins, entry timing.`;
  } else {
    const c=topic.data||{};
    const chg=(c.change||0).toFixed(2);
    const ai=S.intel.dramaCoins.find(d=>d.symbol===c.symbol);
    topicCtx=`COIN: $${c.symbol} (${c.name})
Price: $${fmtP(c.price)} | 24h: ${parseFloat(chg)>=0?'+':''}${chg}%
Volume: $${fmtV(c.volume)} | Type: ${c.type}
Narrative: ${c.narrative||ai?.narrative||'General market'}
Live signal: ${ai?.signal||c.dramaLabel||'price action'}
Write: what's driving this, what to watch next, structural shift vs noise.`;
  }

  const system=`You are a top-tier crypto analyst and social media content creator.

Tone: ${toneMap[tone]}
Language: ${langMap[lang]}
Length: ${lenMap[plen]}

LIVE MARKET DATA (real-time, fetched just now — use to make post timely):
${liveCtx||'No live data yet — write based on topic data provided.'}

CRITICAL RULES:
- NEVER mention any exchange name (Binance, Coinbase, OKX, Bybit, Kraken, etc.)
- NEVER use exchange-branded hashtags
- Platform-neutral content — focus on ASSET/NARRATIVE only
- Hashtags: $TICKER format + topical tags (#Bitcoin #Crypto #DeFi #Web3 #Altcoin #Airdrop #DePIN #RWA #BTCfi #AIcrypto etc.) — MAX 6 total
- Sound human, not AI-generated
- Vary opening hooks — NEVER start with "So," / "Let me explain" / "In the world of"
- ONE main insight per post — don't try to cover everything
- No specific buy/sell price recommendations${extras.length?'\n\nExtra requirements:\n'+extras.map(e=>'- '+e).join('\n'):''}${custom?'\n\nOperator instructions: '+custom:''}`;

  return{system,user:`Write a crypto social post about:\n\n${topicCtx}\n\nReturn ONLY the post + hashtags. Nothing else.`};
}

// ═══════ 8. GENERATE ═══════
async function genPost(topic){
  const{system,user}=buildPrompt(topic);
  return await callOAI({system,user,webSearch:false});
}

// ═══════ 9. POST TO PLATFORM ═══════
async function postTo(content){
  const p=$('platform').value;
  if(p==='preview') return{ok:true,id:'PREVIEW_'+Date.now(),sim:true};
  if(p==='telegram'){
    const tok=$('tg-tok').value.trim(),ch=$('tg-ch').value.trim();
    if(!tok||!ch) throw new Error('Thiếu Telegram bot token / channel ID');
    const r=await fetch(`https://api.telegram.org/bot${tok}/sendMessage`,{
      method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({chat_id:ch,text:content})
    });
    const d=await r.json();
    if(!d.ok) throw new Error(d.description||'Telegram error');
    return{ok:true,id:'TG_'+d.result.message_id};
  }
  log('warn','['+p+'] Backend HMAC signing needed. Simulated.');
  return{ok:true,id:p.toUpperCase()+'_'+Date.now(),sim:true};
}

// ═══════ 10. MAIN CYCLE ═══════
async function runCycle(doPost=true){
  log('info','── New cycle ──');
  await fetchMkt();
  // Refresh AI intel every 3 cycles to save API calls
  if(S.posted%3===0||!S.intel.drama){
    await fetchIntel();
    if(!S.narratives.length) await fetchNarr();
    if(!S.airdrops.length) await fetchAir();
  }
  const topic=pickTopic();
  log('info','Topic: ['+topic.type+'] '+(topic.data?.name||topic.data?.symbol||'?'));
  log('info','Generating post...');
  let content;
  try{content=await genPost(topic);log('ok','Generated ('+content.length+' chars)');}
  catch(e){log('err','Generate error: '+e.message);return;}
  showPreview(content,topic);
  if(doPost){
    try{
      const res=await postTo(content);
      if(res.ok){S.posted++;$('m-post').textContent=S.posted;log('ok','✓ Posted #'+S.posted+' — '+res.id+(res.sim?' [SIM]':''));addHist(content,topic,res.id);}
    }catch(e){log('err','Post error: '+e.message);}
  }
}

// ═══════ UI ═══════
function showPreview(content,topic){
  const cm={airdrop:'var(--green)',narrative:'var(--purple)',offchain:'var(--accent)',futures:'var(--purple)',spot:'var(--blue)'};
  const lm={airdrop:'AIRDROP',narrative:'NARRATIVE',offchain:'OFF-CHAIN',futures:'FUTURES',spot:'SPOT'};
  const color=cm[topic.type]||'var(--accent)',label=lm[topic.type]||'POST',name=topic.data?.name||topic.data?.symbol||'?';
  $('prev-empty').style.display='none';$('prev-content').style.display='block';
  $('prev-content').innerHTML=`<div class="post-card"><div class="post-meta"><span class="badge" style="background:rgba(0,0,0,.2);color:${color};border:1px solid ${color}40;font-size:9px">${label}</span><span class="badge spot" style="font-size:9px">${esc(name)}</span><span style="font-family:var(--mono);font-size:10px;color:var(--text3)">${new Date().toLocaleString('vi-VN')}</span></div><div class="post-body">${esc(content)}</div></div>`;
  st('preview');
}
function addHist(content,topic,id){
  const el=$('hist-list');
  if(el.children[0]?.textContent?.includes('Chưa có')) el.innerHTML='';
  const div=document.createElement('div');div.className='post-card';
  div.innerHTML=`<div class="post-meta"><span class="badge spot" style="font-size:9px">${esc(topic.data?.symbol||topic.data?.name||topic.type)}</span><span style="font-family:var(--mono);font-size:10px;color:var(--text3)">${new Date().toLocaleString('vi-VN')} — ${id}</span></div><div class="post-body" style="max-height:80px;overflow:hidden">${esc(content.substring(0,280))}${content.length>280?'...':''}</div>`;
  el.prepend(div);
}

// ═══════ BOT CONTROL ═══════
async function startBot(){
  S.running=true;$('btn-start').disabled=true;$('btn-stop').disabled=false;
  $('spill').className='status-pill running';$('stext').textContent='RUNNING';
  log('ok','Bot started!');
  const ms=+$('interval').value*60000;
  await runCycle(true);
  S.timer=setInterval(async()=>{if(!S.running)return;S.nextRun=Date.now()+ms;await runCycle(true);},ms);
  S.nextRun=Date.now()+ms;startCD();
}
function stopBot(){
  S.running=false;clearInterval(S.timer);clearInterval(S.cdt);S.nextRun=null;
  $('btn-start').disabled=false;$('btn-stop').disabled=true;
  $('spill').className='status-pill';$('stext').textContent='STOPPED';
  $('m-cd').textContent='—';$('next-label').textContent='—';
  log('warn','Bot stopped.');
}
async function runOnce(){log('info','Manual run...');await runCycle(true);}
async function previewOnly(){
  log('info','Preview...');
  if(!S.coins.length) await fetchMkt();
  const topic=pickTopic();
  try{const c=await genPost(topic);showPreview(c,topic);log('ok','Preview: '+topic.type);}
  catch(e){log('err',e.message);}
}
function startCD(){
  if(S.cdt) clearInterval(S.cdt);
  S.cdt=setInterval(()=>{
    if(!S.nextRun)return;
    const d=S.nextRun-Date.now();
    if(d<=0){$('m-cd').textContent='00:00';return;}
    const m=Math.floor(d/60000).toString().padStart(2,'0'),sec=Math.floor((d%60000)/1000).toString().padStart(2,'0');
    $('m-cd').textContent=m+':'+sec;
    $('next-label').textContent='Next: '+new Date(S.nextRun).toLocaleTimeString('vi-VN');
  },1000);
}
