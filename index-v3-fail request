<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Crypto Auto Post Pro</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
:root{--bg:#0a0c0f;--bg2:#111418;--bg3:#181d23;--bg4:#1e252e;--border:#2a3340;--border2:#3a4755;--text:#e8edf2;--text2:#8a9ab0;--text3:#4a5a6e;--accent:#f0b90b;--accent2:#d4a00a;--green:#0ecb81;--red:#f6465d;--blue:#1e88e5;--purple:#7b61ff;--orange:#ff8c00;--mono:'IBM Plex Mono',monospace;--sans:'IBM Plex Sans',sans-serif;}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:var(--sans);background:var(--bg);color:var(--text);min-height:100vh;font-size:14px;}
.topbar{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 2rem;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;}
.logo{display:flex;align-items:center;gap:10px;font-family:var(--mono);font-weight:600;font-size:15px;letter-spacing:.03em;}
.logo-dot{width:8px;height:8px;background:var(--accent);border-radius:50%;animation:pulse 2s ease-in-out infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.4)}}
.status-pill{display:flex;align-items:center;gap:6px;font-family:var(--mono);font-size:11px;padding:4px 12px;border-radius:20px;border:1px solid var(--border);color:var(--text2);background:var(--bg3);transition:all .3s;}
.status-pill.running{border-color:var(--green);color:var(--green);background:rgba(14,203,129,.08);}
.status-dot{width:6px;height:6px;border-radius:50%;background:currentColor;}
.status-pill.running .status-dot{animation:pulse 1.2s ease-in-out infinite;}
.container{display:grid;grid-template-columns:320px 1fr;height:calc(100vh - 56px);}
.sidebar{background:var(--bg2);border-right:1px solid var(--border);overflow-y:auto;padding:1.25rem;display:flex;flex-direction:column;gap:1.25rem;}
.main{overflow-y:auto;padding:1.5rem;display:flex;flex-direction:column;gap:1.5rem;}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:1rem 1.25rem;}
.card-title{font-family:var(--mono);font-size:10px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--text3);margin-bottom:12px;}
label{font-size:11px;color:var(--text2);font-weight:500;letter-spacing:.04em;display:block;margin-bottom:4px;margin-top:10px;}
label:first-child{margin-top:0;}
input[type=text],input[type=password],input[type=number],select,textarea{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:6px;color:var(--text);font-family:var(--mono);font-size:12px;padding:8px 10px;outline:none;transition:border-color .2s;}
input:focus,select:focus,textarea:focus{border-color:var(--accent);}
select option{background:var(--bg3);}
textarea{resize:vertical;min-height:60px;line-height:1.6;}
.input-hint{font-size:10px;color:var(--text3);margin-top:3px;font-family:var(--mono);}
.tr{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;}
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:6px;border:1px solid var(--border2);background:var(--bg3);color:var(--text);font-family:var(--mono);font-size:12px;font-weight:500;cursor:pointer;transition:all .15s;white-space:nowrap;}
.btn:hover{background:var(--bg4);border-color:var(--text3);}
.btn.accent{background:var(--accent);border-color:var(--accent2);color:#000;font-weight:600;}
.btn.accent:hover{background:var(--accent2);}
.btn.red{background:rgba(246,70,93,.1);border-color:var(--red);color:var(--red);}
.btn.green{background:rgba(14,203,129,.1);border-color:var(--green);color:var(--green);}
.btn:disabled{opacity:.4;cursor:not-allowed;}
.metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;}
.metric{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:1rem;}
.metric-label{font-size:10px;font-family:var(--mono);color:var(--text3);letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px;}
.metric-val{font-size:22px;font-weight:600;font-family:var(--mono);}
.metric-sub{font-size:10px;color:var(--text3);margin-top:4px;font-family:var(--mono);}
.mkt-table{width:100%;border-collapse:collapse;font-family:var(--mono);font-size:12px;}
.mkt-table th{text-align:left;color:var(--text3);font-size:10px;letter-spacing:.1em;text-transform:uppercase;padding:6px 8px;border-bottom:1px solid var(--border);}
.mkt-table td{padding:7px 8px;border-bottom:1px solid var(--bg3);}
.mkt-table tr:last-child td{border:none;}
.mkt-table tr:hover td{background:var(--bg3);}
.cn{font-weight:600;color:var(--text);}
.ct{font-size:10px;color:var(--text3);}
.up{color:var(--green);}.down{color:var(--red);}
.badge{display:inline-block;font-size:9px;padding:2px 6px;border-radius:4px;font-weight:600;letter-spacing:.05em;}
.badge.spot{background:rgba(30,136,229,.15);color:#64b5f6;border:1px solid rgba(30,136,229,.3);}
.badge.futures{background:rgba(123,97,255,.15);color:#b39ddb;border:1px solid rgba(123,97,255,.3);}
.badge.off{background:rgba(240,185,11,.1);color:var(--accent);border:1px solid rgba(240,185,11,.3);}
.badge.drama{background:rgba(246,70,93,.12);color:#ff8a95;border:1px solid rgba(246,70,93,.3);}
.badge.air{background:rgba(14,203,129,.12);color:var(--green);border:1px solid rgba(14,203,129,.3);}
.badge.narr{background:rgba(123,97,255,.12);color:#b39ddb;border:1px solid rgba(123,97,255,.3);}
.badge.gem{background:rgba(255,140,0,.15);color:var(--orange);border:1px solid rgba(255,140,0,.4);}
.badge.hot{background:rgba(246,70,93,.15);color:#ff8a95;border:1px solid rgba(246,70,93,.4);}
.log-wrap{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:.75rem 1rem;max-height:300px;overflow-y:auto;font-family:var(--mono);font-size:11px;line-height:1.8;}
.log-line{display:flex;gap:10px;}
.log-ts{color:var(--text3);min-width:75px;}
.log-ok{color:var(--green);}.log-err{color:var(--red);}.log-info{color:#64b5f6;}.log-warn{color:var(--accent);}
.post-card{background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:1rem 1.25rem;position:relative;overflow:hidden;margin-bottom:10px;}
.post-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--accent);}
.post-meta{display:flex;align-items:center;gap:8px;margin-bottom:8px;flex-wrap:wrap;}
.post-body{font-size:13px;line-height:1.8;color:var(--text);white-space:pre-wrap;}
.countdown{font-family:var(--mono);font-size:22px;font-weight:600;color:var(--accent);}
.spin{display:inline-block;animation:rotate .8s linear infinite;}
@keyframes rotate{to{transform:rotate(360deg)}}
.sep{height:1px;background:var(--border);margin:8px 0;}
::-webkit-scrollbar{width:4px;}::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}
.tabs{display:flex;border-bottom:1px solid var(--border);margin-bottom:16px;flex-wrap:wrap;}
.tab{padding:8px 13px;font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:.06em;text-transform:uppercase;color:var(--text3);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .15s;}
.tab:hover{color:var(--text2);}.tab.active{color:var(--accent);border-bottom-color:var(--accent);}
.tab-panel{display:none;}.tab-panel.active{display:block;}
.ratio-bar{display:flex;height:8px;border-radius:4px;overflow:hidden;gap:2px;margin:6px 0;}
.ratio-seg{height:100%;border-radius:2px;transition:width .4s;}
.db{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:12px;margin-bottom:8px;}
.db-title{font-family:var(--mono);font-size:11px;font-weight:600;color:var(--accent);margin-bottom:6px;display:flex;align-items:center;justify-content:space-between;}
.db-body{font-size:12px;color:var(--text2);line-height:1.7;}
.tag-row{display:flex;gap:4px;flex-wrap:wrap;margin-top:6px;}
.chip{font-family:var(--mono);font-size:10px;padding:2px 8px;border-radius:4px;background:var(--bg4);border:1px solid var(--border);color:var(--text2);}
.chip.on{background:rgba(240,185,11,.08);border-color:rgba(240,185,11,.4);color:var(--accent);}
input[type=range]{-webkit-appearance:none;width:100%;height:4px;background:var(--border2);border-radius:2px;outline:none;margin:4px 0;}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:14px;height:14px;border-radius:50%;background:var(--accent);cursor:pointer;}
.overlay{display:none;position:fixed;inset:0;background:rgba(10,12,15,.9);z-index:200;align-items:center;justify-content:center;flex-direction:column;gap:16px;}
.overlay.show{display:flex;}
.ov-spin{font-size:36px;animation:rotate 1s linear infinite;color:var(--accent);}
.ov-title{font-family:var(--mono);font-size:13px;color:var(--accent);letter-spacing:.06em;}
.ov-step{font-family:var(--mono);font-size:11px;color:var(--text3);text-align:center;max-width:400px;line-height:2;}
.pbar{width:320px;height:3px;background:var(--border);border-radius:2px;overflow:hidden;}
.pfill{height:100%;background:var(--accent);border-radius:2px;transition:width .6s ease;}
</style>
</head>
<body>

<div class="overlay" id="ov">
  <div class="ov-spin">⟳</div>
  <div class="ov-title" id="ov-title">ĐANG QUÉT</div>
  <div class="pbar"><div class="pfill" id="ov-pfill" style="width:0%"></div></div>
  <div class="ov-step" id="ov-step">Khởi động...</div>
</div>

<div class="topbar">
  <div class="logo"><div class="logo-dot"></div>CRYPTO AUTO POST PRO</div>
  <div style="display:flex;align-items:center;gap:12px;">
    <span style="font-family:var(--mono);font-size:11px;color:var(--text3);" id="next-label">—</span>
    <div class="status-pill" id="spill"><div class="status-dot"></div><span id="stext">STOPPED</span></div>
  </div>
</div>

<div class="container">
<div class="sidebar">

  <div class="card">
    <div class="card-title">⚙ Config</div>
    <label>OpenAI API Key <span style="color:var(--red)">*</span></label>
    <input type="password" id="oai-key" placeholder="sk-..." autocomplete="off"/>
    <div class="input-hint">Dùng cho generate bài + web search real-time data</div>
    <div class="sep"></div>
    <label>Platform</label>
    <select id="platform" onchange="switchPlat()">
      <option value="preview">Preview Only</option>
      <option value="telegram">Telegram Channel</option>
      <option value="binance">Binance Square</option>
    </select>
    <div id="tg-f" style="display:none">
      <label>Bot Token</label><input type="password" id="tg-tok" placeholder="123456:ABC..."/>
      <label>Channel ID</label><input type="text" id="tg-ch" placeholder="@channel"/>
    </div>
    <div id="bn-f" style="display:none">
      <label>Binance API Key</label><input type="password" id="bn-key" placeholder="API key..."/>
      <label>Binance Secret</label><input type="password" id="bn-sec" placeholder="Secret..."/>
      <div class="input-hint">⚠ Cần backend HMAC để đăng thật</div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">⏱ Schedule</div>
    <label>Interval (phút)</label>
    <input type="number" id="interval" value="30" min="5" max="1440"/>
    <div class="sep"></div>
    <div style="font-family:var(--mono);font-size:10px;color:var(--text3);letter-spacing:.1em;margin-bottom:8px;">TỈ LỆ NỘI DUNG</div>
    <div class="tr"><span style="font-size:11px;color:var(--text2);">Spot drama</span><span style="font-family:var(--mono);font-size:11px;color:var(--blue)" id="p-spot">20%</span></div>
    <input type="range" id="r-spot" min="0" max="60" value="20"/>
    <div class="tr"><span style="font-size:11px;color:var(--text2);">Futures/Perp</span><span style="font-family:var(--mono);font-size:11px;color:var(--purple)" id="p-fut">15%</span></div>
    <input type="range" id="r-fut" min="0" max="60" value="15"/>
    <div class="tr"><span style="font-size:11px;color:var(--text2);">Narrative/Sector</span><span style="font-family:var(--mono);font-size:11px;color:#9c27b0" id="p-narr">25%</span></div>
    <input type="range" id="r-narr" min="0" max="60" value="25"/>
    <div class="tr"><span style="font-size:11px;color:var(--text2);">Airdrop/Pre-listing</span><span style="font-family:var(--mono);font-size:11px;color:var(--green)" id="p-air">20%</span></div>
    <input type="range" id="r-air" min="0" max="50" value="20"/>
    <div class="tr"><span style="font-size:11px;color:var(--text2);">Off-chain/Non-listed</span><span style="font-family:var(--mono);font-size:11px;color:var(--accent)" id="p-off">20%</span></div>
    <div class="ratio-bar">
      <div class="ratio-seg" id="rs-s" style="background:var(--blue);width:20%"></div>
      <div class="ratio-seg" id="rs-f" style="background:var(--purple);width:15%"></div>
      <div class="ratio-seg" id="rs-n" style="background:#9c27b0;width:25%"></div>
      <div class="ratio-seg" id="rs-a" style="background:var(--green);width:20%"></div>
      <div class="ratio-seg" id="rs-o" style="background:var(--accent);width:20%"></div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">✍ Post Settings</div>
    <label>Ngôn ngữ</label>
    <select id="lang"><option value="vi">Tiếng Việt</option><option value="en">English</option><option value="bilingual">Song ngữ VI/EN</option></select>
    <label>Độ dài</label>
    <select id="plen"><option value="short">Ngắn ~150 từ</option><option value="medium" selected>Vừa ~300 từ</option><option value="long">Dài ~500 từ</option></select>
    <label>Tone</label>
    <select id="tone">
      <option value="drama" selected>Drama / FOMO</option>
      <option value="analytical">Phân tích chuyên sâu</option>
      <option value="educational">Giáo dục / Tutorial</option>
      <option value="alpha">Alpha / Insider</option>
      <option value="thread">Thread 1/n style</option>
      <option value="degen">Degen CT style</option>
    </select>
    <label style="margin-top:10px;">Bổ sung</label>
    <div style="display:flex;flex-direction:column;gap:5px;margin-top:4px;">
      <label style="display:flex;align-items:center;gap:6px;margin:0;cursor:pointer;font-size:11px;"><input type="checkbox" id="i-oc" checked style="width:auto"> On-chain signals</label>
      <label style="display:flex;align-items:center;gap:6px;margin:0;cursor:pointer;font-size:11px;"><input type="checkbox" id="i-sent" checked style="width:auto"> Market sentiment</label>
      <label style="display:flex;align-items:center;gap:6px;margin:0;cursor:pointer;font-size:11px;"><input type="checkbox" id="i-ta" checked style="width:auto"> Technical hints</label>
      <label style="display:flex;align-items:center;gap:6px;margin:0;cursor:pointer;font-size:11px;"><input type="checkbox" id="i-mac" style="width:auto"> Macro context</label>
      <label style="display:flex;align-items:center;gap:6px;margin:0;cursor:pointer;font-size:11px;"><input type="checkbox" id="i-risk" checked style="width:auto"> Risk disclaimer</label>
    </div>
    <label style="margin-top:10px;">Custom instructions</label>
    <textarea id="custom" placeholder="VD: Luôn đề cập risk/reward..."></textarea>
    <label>Blacklist coins</label>
    <input type="text" id="blist" placeholder="LUNA, FTT, SQUID..."/>
  </div>

  <div class="card">
    <div class="card-title">🎮 Control</div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:8px;">
      <button class="btn accent" id="btn-start" onclick="startBot()">▶ Start</button>
      <button class="btn red" id="btn-stop" onclick="stopBot()" disabled>■ Stop</button>
    </div>
    <div style="display:flex;flex-direction:column;gap:6px;">
      <button class="btn" style="width:100%" onclick="runOnce()">↻ Chạy 1 lần</button>
      <button class="btn" style="width:100%" onclick="previewOnly()">👁 Preview (không đăng)</button>
      <button class="btn green" style="width:100%" onclick="fullScan()">🔍 Full scan thị trường</button>
    </div>
  </div>

</div>

<div class="main">
  <div class="metrics">
    <div class="metric"><div class="metric-label">Bài đã đăng</div><div class="metric-val" style="color:var(--accent)" id="m-post">0</div><div class="metric-sub">tổng cộng</div></div>
    <div class="metric"><div class="metric-label">Coins scanned</div><div class="metric-val" style="color:var(--green)" id="m-coins">0</div><div class="metric-sub">real-time</div></div>
    <div class="metric"><div class="metric-label">Last AI scan</div><div class="metric-val" id="m-scan" style="font-size:14px;color:var(--text2)">—</div><div class="metric-sub">web search</div></div>
    <div class="metric"><div class="metric-label">Đăng tiếp theo</div><div class="countdown" id="m-cd">—</div><div class="metric-sub">mm:ss</div></div>
  </div>

  <div class="card" style="padding:1.25rem">
    <div class="tabs">
      <div class="tab active" onclick="st('market')">📈 Market</div>
      <div class="tab" onclick="st('intel')">🧠 AI Intel</div>
      <div class="tab" onclick="st('narratives')">🔥 Narratives</div>
      <div class="tab" onclick="st('airdrops')">🪂 Airdrops</div>
      <div class="tab" onclick="st('preview')">📝 Preview</div>
      <div class="tab" onclick="st('log')">🖥 Log</div>
      <div class="tab" onclick="st('history')">📚 History</div>
    </div>

    <!-- MARKET -->
    <div class="tab-panel active" id="tab-market">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;flex-wrap:wrap;gap:8px;">
        <span style="font-size:11px;color:var(--text3);font-family:var(--mono)" id="mkt-ts">Chưa quét</span>
        <button class="btn" onclick="fetchMkt()" id="btn-mkt"><span id="mkt-ic">⟳</span> Quét giá real-time</button>
      </div>
      <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px">
        <button class="btn" onclick="flt('all')" style="font-size:11px;padding:4px 10px">Tất cả</button>
        <button class="btn" onclick="flt('drama')" style="font-size:11px;padding:4px 10px">🔥 Drama</button>
        <button class="btn" onclick="flt('futures')" style="font-size:11px;padding:4px 10px">Futures</button>
        <button class="btn" onclick="flt('off')" style="font-size:11px;padding:4px 10px">Off-chain</button>
        <button class="btn" onclick="flt('gem')" style="font-size:11px;padding:4px 10px">💎 Gem</button>
      </div>
      <div style="overflow-x:auto">
        <table class="mkt-table">
          <thead><tr><th>Coin</th><th>Type</th><th>Giá</th><th>24h</th><th>Volume</th><th>Narrative</th><th>Signal</th></tr></thead>
          <tbody id="mkt-body"><tr><td colspan="7" style="text-align:center;color:var(--text3);padding:2rem;font-family:var(--mono)">Nhấn "Quét giá" hoặc "Full scan"</td></tr></tbody>
        </table>
      </div>
    </div>

    <!-- AI INTEL -->
    <div class="tab-panel" id="tab-intel">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
        <div>
          <div style="font-family:var(--mono);font-size:10px;color:var(--text3);letter-spacing:.1em">AI WEB SEARCH INTEL — 100% REAL-TIME</div>
          <div style="font-size:11px;color:var(--text2);margin-top:3px">AI search web để lấy funding rates, whale moves, drama signals ngay lúc này</div>
        </div>
        <button class="btn" onclick="fetchIntel()" id="btn-intel"><span id="intel-ic">⟳</span> Scan ngay</button>
      </div>
      <div class="db"><div class="db-title">📊 Funding Rates &amp; Open Interest <span class="badge narr" style="font-size:8px" id="fund-ts">—</span></div><div class="db-body" id="fund-body">Chưa có — nhấn Scan ngay</div></div>
      <div class="db"><div class="db-title">🐋 Whale Moves &amp; On-chain Activity <span class="badge narr" style="font-size:8px" id="whale-ts">—</span></div><div class="db-body" id="whale-body">Chưa có</div></div>
      <div class="db"><div class="db-title">⚡ Drama Signals &amp; Breaking News <span class="badge hot" style="font-size:8px" id="drama-ts">—</span></div><div class="db-body" id="drama-body">Chưa có</div><div class="tag-row" id="drama-tags"></div></div>
      <div class="db"><div class="db-title">📋 Futures Coins List (AI-updated) <span class="badge gem" style="font-size:8px" id="fut-ts">—</span></div><div class="tag-row" id="fut-tags"><span style="font-size:11px;color:var(--text3);font-family:var(--mono)">Chưa fetch</span></div></div>
    </div>

    <!-- NARRATIVES -->
    <div class="tab-panel" id="tab-narratives">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
        <div>
          <div style="font-family:var(--mono);font-size:10px;color:var(--text3);letter-spacing:.1em">NARRATIVE RADAR — AI FETCHED REAL-TIME</div>
          <div style="font-size:11px;color:var(--text2);margin-top:3px">AI tìm narrative đang trending trên CT/Reddit/Discord hôm nay</div>
        </div>
        <button class="btn" onclick="fetchNarr()" id="btn-narr"><span id="narr-ic">⟳</span> Fetch narratives</button>
