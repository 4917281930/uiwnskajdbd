async function fetchMarket() {
  const icon = document.getElementById('fetch-icon');
  const btn = document.getElementById('btn-fetch');
  icon.className = 'spin'; btn.disabled = true;
  addLog('info', 'Đang quét thị trường từ nhiều nguồn...');

  try {
    // 1. Top 250 coins
    const url = 'https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&order=market_cap_desc&per_page=250&page=1&sparkline=false&price_change_percentage=24h,7d';
    const res = await fetch(url);
    const data = await res.json();
    addLog('ok', `✓ CoinGecko: ${data.length} coins`);

    // 2. Trending
    let trendingCoins = [];
    try {
      const tRes = await fetch('https://api.coingecko.com/api/v3/search/trending');
      const tData = await tRes.json();
      trendingCoins = (tData.coins || []).map(c => c.item.symbol.toUpperCase());
      addLog('ok', `✓ Trending: ${trendingCoins.join(', ')}`);
      state.trendCount = trendingCoins.length;
      document.getElementById('m-trends').textContent = NARRATIVES.length + trendingCoins.length;
    } catch(e) { addLog('warn', 'Trending fetch failed, dùng fallback'); }

    // 3. Global market data
    try {
      const gRes = await fetch('https://api.coingecko.com/api/v3/global');
      const gData = await gRes.json();
      const btcDom = gData.data?.market_cap_percentage?.btc?.toFixed(1);
      const totalMcap = formatVol(gData.data?.total_market_cap?.usd);
      addLog('info', `📊 Market cap: $${totalMcap} | BTC dominance: ${btcDom}%`);
    } catch(e) {}

    // 4. Fear & Greed
    try {
      const fgRes = await fetch('https://api.alternative.me/fng/?limit=1');
      const fgData = await fgRes.json();
      const fgVal = fgData.data[0];
      addLog('info', `😨 Fear & Greed: ${fgVal.value} (${fgVal.value_classification})`);
    } catch(e) {}

    // Build market data
    const FUTURES_COINS = new Set(['BTC','ETH','BNB','SOL','ADA','XRP','DOGE','AVAX','LINK','DOT','MATIC','UNI','ATOM','LTC','BCH','TRX','NEAR','FTM','ICP','OP','ARB','APT','SUI','INJ','WLD','PEPE','WIF','TON','BONK','FLOKI','SEI','TIA','PYTH','JTO','JUP']);

    state.marketData = data.map(coin => {
      const sym = coin.symbol.toUpperCase();
      let type = 'spot';
      if (FUTURES_COINS.has(sym)) type = 'both';

      // Category tags
      const cats = [];
      for (const [cat, list] of Object.entries(COIN_CATEGORIES)) {
        if (list.includes(sym)) cats.push(cat);
      }

      // Drama detection
      const chg24 = coin.price_change_percentage_24h || 0;
      const chg7d = coin.price_change_percentage_7d_in_currency || 0;
      const isDrama = Math.abs(chg24) > 8 || Math.abs(chg7d) > 20;
      const isTrending = trendingCoins.includes(sym);

      let signal = '—';
      if (isTrending) signal = '🔥 Trending';
      else if (chg24 > 15) signal = '🚀 Pump mạnh';
      else if (chg24 > 8) signal = '📈 Tăng mạnh';
      else if (chg24 < -15) signal = '💥 Dump mạnh';
      else if (chg24 < -8) signal = '📉 Giảm mạnh';
      else if (Math.abs(chg7d) > 30) signal = '⚡ 7d biến động';

      return {
        symbol: sym, name: coin.name, id: coin.id,
        price: coin.current_price,
        change24: chg24, change7d: chg7d,
        volume: coin.total_volume,
        marketCap: coin.market_cap,
        rank: coin.market_cap_rank,
        type, cats,
        drama: isDrama || isTrending,
        trending: isTrending,
        signal,
      };
    });

    document.getElementById('m-coins').textContent = state.marketData.length;
    document.getElementById('m-coins-sub').textContent = `${trendingCoins.length} trending`;
    document.getElementById('market-update-time').textContent = 'Cập nhật: ' + new Date().toLocaleTimeString('vi-VN');
    addLog('ok', `✓ Tổng cộng: ${state.marketData.length} coins đã quét`);
    renderMarketTable();

  } catch(e) {
    addLog('err', 'Lỗi fetch market: ' + e.message);
  }

  icon.className = ''; icon.textContent = '⟳'; btn.disabled = false;
}

