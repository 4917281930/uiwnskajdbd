<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Crypto Auto Post Tool</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg: #0a0c0f;
    --bg2: #111418;
    --bg3: #181d23;
    --bg4: #1e252e;
    --border: #2a3340;
    --border2: #3a4755;
    --text: #e8edf2;
    --text2: #8a9ab0;
    --text3: #4a5a6e;
    --accent: #f0b90b;
    --accent2: #d4a00a;
    --green: #0ecb81;
    --red: #f6465d;
    --blue: #1e88e5;
    --purple: #7b61ff;
    --teal: #00bcd4;
    --orange: #ff9800;
    --mono: 'IBM Plex Mono', monospace;
    --sans: 'IBM Plex Sans', sans-serif;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: var(--sans); background: var(--bg); color: var(--text); min-height: 100vh; font-size: 14px; }

  .topbar {
    background: var(--bg2); border-bottom: 1px solid var(--border);
    padding: 0 2rem; height: 56px; display: flex; align-items: center;
    justify-content: space-between; position: sticky; top: 0; z-index: 100;
  }
  .logo { display: flex; align-items: center; gap: 10px; font-family: var(--mono); font-weight: 600; font-size: 15px; letter-spacing: 0.03em; }
  .logo-dot { width: 8px; height: 8px; background: var(--accent); border-radius: 50%; animation: pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(1.4)} }
  .status-pill { display: flex; align-items: center; gap: 6px; font-family: var(--mono); font-size: 11px; padding: 4px 12px; border-radius: 20px; border: 1px solid var(--border); color: var(--text2); background: var(--bg3); cursor: default; transition: all 0.3s; }
  .status-pill.running { border-color: var(--green); color: var(--green); background: rgba(14,203,129,0.08); }
  .status-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
  .status-pill.running .status-dot { animation: pulse 1.2s ease-in-out infinite; }

  .container { display: grid; grid-template-columns: 340px 1fr; height: calc(100vh - 56px); }
  .sidebar { background: var(--bg2); border-right: 1px solid var(--border); overflow-y: auto; padding: 1.25rem; display: flex; flex-direction: column; gap: 1.25rem; }
  .main { overflow-y: auto; padding: 1.5rem; display: flex; flex-direction: column; gap: 1.5rem; }

  .card { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 1rem 1.25rem; }
  .card-title { font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text3); margin-bottom: 12px; display: flex; align-items: center; justify-content: space-between; }
  .card-title span { color: var(--accent); }

  label { font-size: 11px; color: var(--text2); font-weight: 500; letter-spacing: 0.04em; display: block; margin-bottom: 4px; margin-top: 10px; }
  label:first-child { margin-top: 0; }
  input[type=text], input[type=password], input[type=number], select, textarea { width: 100%; background: var(--bg3); border: 1px solid var(--border); border-radius: 6px; color: var(--text); font-family: var(--mono); font-size: 12px; padding: 8px 10px; outline: none; transition: border-color 0.2s; }
  input:focus, select:focus, textarea:focus { border-color: var(--accent); }
  select option { background: var(--bg3); }
  textarea { resize: vertical; min-height: 60px; line-height: 1.6; }
  .input-hint { font-size: 10px; color: var(--text3); margin-top: 3px; font-family: var(--mono); }

  .toggle-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px; }
  .toggle-label { font-size: 12px; color: var(--text2); }
  .toggle { position: relative; width: 36px; height: 20px; cursor: pointer; }
  .toggle input { opacity: 0; width: 0; height: 0; }
  .toggle-track { position: absolute; inset: 0; background: var(--bg4); border: 1px solid var(--border2); border-radius: 10px; transition: all 0.25s; }
  .toggle input:checked + .toggle-track { background: var(--accent); border-color: var(--accent); }
  .toggle-thumb { position: absolute; top: 3px; left: 3px; width: 12px; height: 12px; background: var(--text2); border-radius: 50%; transition: all 0.25s; }
  .toggle input:checked ~ .toggle-thumb { left: 19px; background: var(--bg); }

  .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 6px; border: 1px solid var(--border2); background: var(--bg3); color: var(--text); font-family: var(--mono); font-size: 12px; font-weight: 500; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
  .btn:hover { background: var(--bg4); border-color: var(--text3); }
  .btn.accent { background: var(--accent); border-color: var(--accent2); color: #000; font-weight: 600; }
  .btn.accent:hover { background: var(--accent2); }
  .btn.red { background: rgba(246,70,93,0.1); border-color: var(--red); color: var(--red); }
  .btn.red:hover { background: rgba(246,70,93,0.18); }
  .btn.green { background: rgba(14,203,129,0.1); border-color: var(--green); color: var(--green); }
  .btn.green:hover { background: rgba(14,203,129,0.18); }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .btn-group { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 10px; }

  .metrics { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
  .metric { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 1rem; }
  .metric-label { font-size: 10px; font-family: var(--mono); color: var(--text3); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 6px; }
  .metric-val { font-size: 24px; font-weight: 600; font-family: var(--mono); color: var(--text); }
  .metric-val.green { color: var(--green); }
  .metric-val.red { color: var(--red); }
  .metric-val.yellow { color: var(--accent); }
  .metric-sub { font-size: 10px; color: var(--text3); margin-top: 4px; font-family: var(--mono); }

  .market-table { width: 100%; border-collapse: collapse; font-family: var(--mono); font-size: 12px; }
  .market-table th { text-align: left; color: var(--text3); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; padding: 6px 8px; border-bottom: 1px solid var(--border); }
  .market-table td { padding: 7px 8px; border-bottom: 1px solid var(--bg3); vertical-align: top; }
  .market-table tr:last-child td { border: none; }
  .market-table tr:hover td { background: var(--bg3); }
  .coin-name { font-weight: 600; color: var(--text); }
  .coin-tag { font-size: 10px; color: var(--text3); }
  .up { color: var(--green); }
  .down { color: var(--red); }
  .badge { display: inline-block; font-size: 9px; padding: 2px 6px; border-radius: 4px; font-weight: 600; letter-spacing: 0.05em; }
  .badge.spot { background: rgba(30,136,229,0.15); color: #64b5f6; border: 1px solid rgba(30,136,229,0.3); }
  .badge.futures { background: rgba(123,97,255,0.15); color: #b39ddb; border: 1px solid rgba(123,97,255,0.3); }
  .badge.off-chain { background: rgba(240,185,11,0.1); color: var(--accent); border: 1px solid rgba(240,185,11,0.3); }
  .badge.drama { background: rgba(246,70,93,0.12); color: #ff8a95; border: 1px solid rgba(246,70,93,0.3); }
  .badge.airdrop { background: rgba(0,188,212,0.12); color: var(--teal); border: 1px solid rgba(0,188,212,0.3); }
  .badge.pre-listing { background: rgba(255,152,0,0.12); color: var(--orange); border: 1px solid rgba(255,152,0,0.3); }
  .badge.trend { background: rgba(14,203,129,0.12); color: var(--green); border: 1px solid rgba(14,203,129,0.3); }
  .badge.narrative { background: rgba(123,97,255,0.12); color: var(--purple); border: 1px solid rgba(123,97,255,0.3); }

  .log-wrap { background: var(--bg); border: 1px solid var(--border); border-radius: 8px; padding: 0.75rem 1rem; max-height: 260px; overflow-y: auto; font-family: var(--mono); font-size: 11px; line-height: 1.8; }
  .log-line { display: flex; gap: 10px; }
  .log-ts { color: var(--text3); min-width: 75px; }
  .log-ok { color: var(--green); }
  .log-err { color: var(--red); }
  .log-info { color: #64b5f6; }
  .log-warn { color: var(--accent); }

  .post-card { background: var(--bg3); border: 1px solid var(--border); border-radius: 10px; padding: 1rem 1.25rem; position: relative; overflow: hidden; }
  .post-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--accent); border-radius: 2px 0 0 2px; }
  .post-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; flex-wrap: wrap; }
  .post-type { font-family: var(--mono); font-size: 10px; padding: 2px 8px; border-radius: 4px; font-weight: 600; }
  .post-time { font-family: var(--mono); font-size: 10px; color: var(--text3); }
  .post-body { font-size: 13px; line-height: 1.75; color: var(--text); white-space: pre-wrap; }

  .progress-bar { background: var(--bg4); border-radius: 4px; height: 4px; overflow: hidden; margin: 6px 0; }
  .progress-fill { height: 100%; background: var(--accent); border-radius: 4px; transition: width 0.5s ease; }

  .schedule-row { display: flex; align-items: center; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid var(--bg3); font-family: var(--mono); font-size: 11px; }
  .schedule-row:last-child { border: none; }
  .sched-label { color: var(--text2); }
  .sched-val { color: var(--accent); font-weight: 500; }
  .countdown { font-family: var(--mono); font-size: 22px; font-weight: 600; color: var(--accent); letter-spacing: 0.05em; }

  .spin { display: inline-block; animation: rotate 0.8s linear infinite; }
  @keyframes rotate { to { transform: rotate(360deg); } }
  .sep { height: 1px; background: var(--border); margin: 4px 0; }

  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

  .tabs { display: flex; gap: 0; border-bottom: 1px solid var(--border); margin-bottom: 16px; flex-wrap: wrap; }
  .tab { padding: 8px 14px; font-family: var(--mono); font-size: 11px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text3); cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: all 0.15s; }
  .tab:hover { color: var(--text2); }
  .tab.active { color: var(--accent); border-bottom-color: var(--accent); }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  .ratio-bar { display: flex; height: 8px; border-radius: 4px; overflow: hidden; gap: 2px; margin: 6px 0; }
  .ratio-seg { height: 100%; border-radius: 2px; transition: width 0.5s; }

  /* TREND CARDS */
  .trend-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px; margin-bottom: 16px; }
  .trend-card { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 12px; cursor: pointer; transition: all 0.2s; }
  .trend-card:hover { border-color: var(--accent); background: var(--bg4); }
  .trend-card.selected { border-color: var(--accent); background: rgba(240,185,11,0.05); }
  .trend-title { font-family: var(--mono); font-size: 12px; font-weight: 600; color: var(--text); margin-bottom: 4px; }
  .trend-desc { font-size: 11px; color: var(--text2); line-height: 1.5; }
  .trend-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 8px; }

  /* NARRATIVE PANEL */
  .narrative-list { display: flex; flex-direction: column; gap: 8px; }
  .narrative-item { background: var(--bg3); border: 1px solid var(--border); border-radius: 6px; padding: 10px 12px; display: flex; align-items: flex-start; gap: 10px; cursor: pointer; transition: all 0.15s; }
  .narrative-item:hover { border-color: var(--accent); }
  .narrative-item.selected { border-color: var(--accent); background: rgba(240,185,11,0.05); }
  .narrative-icon { font-size: 18px; flex-shrink: 0; }
  .narrative-info { flex: 1; }
  .narrative-name { font-family: var(--mono); font-size: 12px; font-weight: 600; color: var(--text); }
  .narrative-coins { font-size: 10px; color: var(--accent); margin-top: 2px; font-family: var(--mono); }
  .narrative-desc { font-size: 10px; color: var(--text2); margin-top: 3px; }

  /* SOURCE PANEL */
  .source-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
  .source-item { background: var(--bg3); border: 1px solid var(--border); border-radius: 6px; padding: 8px 10px; }
  .source-name { font-family: var(--mono); font-size: 11px; font-weight: 600; color: var(--text); }
  .source-status { font-size: 10px; margin-top: 2px; }
  .source-ok { color: var(--green); }
  .source-warn { color: var(--accent); }

  /* PRE-LISTING */
  .prelisting-item { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 12px; margin-bottom: 8px; }
  .prelisting-header { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .prelisting-name { font-family: var(--mono); font-size: 13px; font-weight: 600; color: var(--text); }
  .prelisting-meta { font-size: 10px; color: var(--text2); line-height: 1.6; }
  .signal-bar { display: flex; gap: 4px; margin-top: 6px; flex-wrap: wrap; }

  /* COPY BUTTON */
  .copy-btn { font-size: 10px; padding: 3px 8px; margin-left: 8px; }

  /* PROMPT EDITOR */
  .prompt-section { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 12px; margin-bottom: 12px; }
  .prompt-section-title { font-family: var(--mono); font-size: 10px; color: var(--accent); font-weight: 600; letter-spacing: 0.1em; margin-bottom: 8px; }

  input[type=range] { -webkit-appearance: none; width: 100%; height: 4px; border-radius: 2px; background: var(--bg4); outline: none; margin: 4px 0; }
  input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; width: 14px; height: 14px; border-radius: 50%; background: var(--accent); cursor: pointer; }

  .checkbox-row { display: flex; align-items: center; gap: 8px; margin: 4px 0; cursor: pointer; }
  .checkbox-row input[type=checkbox] { width: 14px; height: 14px; accent-color: var(--accent); cursor: pointer; }
  .checkbox-label { font-size: 12px; color: var(--text2); }
</style>
</head>
<body>

<div class="topbar">
  <div class="logo">
    <div class="logo-dot"></div>
    CRYPTO AUTO POST TOOL
  </div>
  <div style="display:flex;align-items:center;gap:12px;">
    <span style="font-family:var(--mono);font-size:11px;color:var(--text3)" id="next-label">—</span>
    <div class="status-pill" id="status-pill">
      <div class="status-dot"></div>
      <span id="status-text">STOPPED</span>
    </div>
  </div>
</div>

<div class="container">

  <!-- SIDEBAR -->
  <div class="sidebar">

    <div class="card">
      <div class="card-title">⚙ API Config</div>
      <label>OpenAI API Key</label>
      <input type="password" id="openai-key" placeholder="sk-..." autocomplete="off"/>
      <div class="input-hint">Dùng GPT-4o để tạo bài chất lượng cao</div>
      <label>Binance API Key (tùy chọn)</label>
      <input type="password" id="binance-key" placeholder="Binance API key..." autocomplete="off"/>
      <label>Binance Secret (tùy chọn)</label>
      <input type="password" id="binance-secret" placeholder="Binance secret..." autocomplete="off"/>
    </div>

    <div class="card">
      <div class="card-title">⏱ Schedule</div>
      <label>Interval (phút)</label>
      <input type="number" id="interval" value="30" min="5" max="1440"/>
      <div class="sep" style="margin:12px 0;"></div>
      <div class="card-title" style="margin-bottom:8px;">📊 Tỉ lệ nội dung</div>
      <div class="toggle-row">
        <span class="toggle-label">Spot / On-chain drama</span>
        <span style="font-family:var(--mono);font-size:11px;color:var(--blue)" id="pct-spot">30%</span>
      </div>
      <input type="range" id="pct-spot-range" min="0" max="70" value="30" style="width:100%;margin-bottom:6px;"/>
      <div class="toggle-row">
        <span class="toggle-label">Futures / Derivatives</span>
        <span style="font-family:var(--mono);font-size:11px;color:var(--purple)" id="pct-futures">25%</span>
      </div>
      <input type="range" id="pct-futures-range" min="0" max="70" value="25" style="width:100%;margin-bottom:6px;"/>
      <div class="toggle-row">
        <span class="toggle-label">Narrative / Trend mới</span>
        <span style="font-family:var(--mono);font-size:11px;color:var(--green)" id="pct-trend">25%</span>
      </div>
      <input type="range" id="pct-trend-range" min="0" max="70" value="25" style="width:100%;margin-bottom:6px;"/>
      <div class="toggle-row">
        <span class="toggle-label">Airdrop / Pre-listing</span>
        <span style="font-family:var(--mono);font-size:11px;color:var(--teal)" id="pct-airdrop">20%</span>
      </div>
      <div class="ratio-bar">
        <div class="ratio-seg" id="rs-spot" style="background:var(--blue);width:30%"></div>
        <div class="ratio-seg" id="rs-fut" style="background:var(--purple);width:25%"></div>
        <div class="ratio-seg" id="rs-trend" style="background:var(--green);width:25%"></div>
        <div class="ratio-seg" id="rs-air" style="background:var(--teal);width:20%"></div>
      </div>
      <div class="input-hint">Tổng = 100%</div>
    </div>

    <div class="card">
      <div class="card-title">✍ Post Settings</div>
      <label>Ngôn ngữ</label>
      <select id="lang">
        <option value="vi">Tiếng Việt</option>
        <option value="en">English</option>
        <option value="bilingual">Song ngữ VI/EN</option>
      </select>
      <label>Độ dài bài</label>
      <select id="post-length">
        <option value="short">Ngắn (~150 từ)</option>
        <option value="medium" selected>Trung bình (~300 từ)</option>
        <option value="long">Chi tiết (~500 từ)</option>
      </select>
      <label>Tone viết</label>
      <select id="tone">
        <option value="analytical">Phân tích chuyên sâu</option>
        <option value="drama" selected>Drama / Hấp dẫn</option>
        <option value="educational">Giáo dục / Giải thích</option>
        <option value="alpha">Alpha / Insider tips</option>
        <option value="degen">Degen / Crypto native</option>
      </select>

      <div class="sep" style="margin:10px 0;"></div>
      <div class="card-title" style="margin-bottom:8px;">🔧 Tùy chỉnh Prompt</div>

      <label class="checkbox-row" style="margin-top:0;">
        <input type="checkbox" id="opt-no-financial-advice" checked/>
        <span class="checkbox-label">Thêm disclaimer "not financial advice"</span>
      </label>
      <label class="checkbox-row">
        <input type="checkbox" id="opt-include-data" checked/>
        <span class="checkbox-label">Luôn đề cập dữ liệu thị trường</span>
      </label>
      <label class="checkbox-row">
        <input type="checkbox" id="opt-call-to-action" checked/>
        <span class="checkbox-label">Thêm call-to-action / câu hỏi cuối</span>
      </label>
      <label class="checkbox-row">
        <input type="checkbox" id="opt-risk-mgmt"/>
        <span class="checkbox-label">Đề cập risk management</span>
      </label>
      <label class="checkbox-row">
        <input type="checkbox" id="opt-on-chain" checked/>
        <span class="checkbox-label">Bao gồm tín hiệu on-chain</span>
      </label>
      <label class="checkbox-row">
        <input type="checkbox" id="opt-no-exchange-tag" checked/>
        <span class="checkbox-label">Không tag tên sàn</span>
      </label>

      <label>Custom Prompt thêm (tùy chọn)</label>
      <textarea id="custom-prompt" placeholder="VD: Luôn so sánh với chu kỳ 2021..."></textarea>
    </div>

    <div class="card">
      <div class="card-title">🎮 Control</div>
      <div class="btn-group">
        <button class="btn accent" id="btn-start" onclick="startBot()">▶ Start Bot</button>
        <button class="btn red" id="btn-stop" onclick="stopBot()" disabled>■ Stop</button>
      </div>
      <div style="margin-top:8px; display:flex; gap:8px;">
        <button class="btn" style="flex:1;" onclick="runOnce()">↻ Chạy 1 lần</button>
        <button class="btn" style="flex:1;" onclick="previewOnly()">👁 Preview</button>
      </div>
      <div style="margin-top:8px;">
        <button class="btn" style="width:100%;color:var(--teal);border-color:rgba(0,188,212,0.3);" onclick="scanAllSources()">🔍 Quét tất cả nguồn</button>
      </div>
    </div>

  </div>

  <!-- MAIN -->
  <div class="main">

    <!-- METRICS -->
    <div class="metrics">
      <div class="metric">
        <div class="metric-label">Bài đã đăng</div>
        <div class="metric-val yellow" id="m-posted">0</div>
        <div class="metric-sub">tổng cộng</div>
      </div>
      <div class="metric">
        <div class="metric-label">Coins scanned</div>
        <div class="metric-val green" id="m-coins">0</div>
        <div class="metric-sub" id="m-coins-sub">đang chờ</div>
      </div>
      <div class="metric">
        <div class="metric-label">Trends phát hiện</div>
        <div class="metric-val" id="m-trends" style="color:var(--teal)">0</div>
        <div class="metric-sub">narratives + signals</div>
      </div>
      <div class="metric">
