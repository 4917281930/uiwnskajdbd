// ═══════════════════════════════════════════
//  PICK COIN/TOPIC LOGIC
// ═══════════════════════════════════════════
function pickTopicForPost() {
  const s = parseInt(spotR.value);
  const f = parseInt(futR.value);
  const t = parseInt(trendR.value);
  const a = 100 - s - f - t;
  const r = Math.random() * 100;

  if (r < a) {
    // Airdrop / Pre-listing
    const p = PRE_LISTING_COINS[Math.floor(Math.random() * PRE_LISTING_COINS.length)];
    return { type: 'pre-listing', coin: null, preItem: p, narrative: null };
  } else if (r < a + t) {
    // Narrative / Trend
    // Prefer selected narrative if any
    const n = state.selectedNarrative
      ? NARRATIVES.find(x => x.id === state.selectedNarrative)
      : NARRATIVES[Math.floor(Math.random() * NARRATIVES.length)];
    // Pick a coin from the narrative
    const sym = n.coins[Math.floor(Math.random() * n.coins.length)];
    const coin = state.marketData.find(c => c.symbol === sym) || { symbol: sym, name: sym, price: 0, change24: 0, volume: 0 };
    return { type: 'narrative', coin, preItem: null, narrative: n };
  } else if (r < a + t + s) {
    // Spot drama
    let pool = state.marketData.filter(c => c.drama);
    if (!pool.length) pool = state.marketData.slice(0, 20);
    const coin = pool[Math.floor(Math.random() * Math.min(pool.length, 15))];
    return { type: 'spot', coin, preItem: null, narrative: null };
  } else {
    // Futures
    let pool = state.marketData.filter(c => c.type === 'both');
    if (!pool.length) pool = state.marketData.slice(0, 10);
    const coin = pool[Math.floor(Math.random() * Math.min(pool.length, 15))];
    return { type: 'futures', coin, preItem: null, narrative: null };
  }
}

