function renderMarketTable(filter) {
  if (filter) state.marketFilter = filter;
  const f = state.marketFilter;
  let data = [...state.marketData];

  if (f === 'spot') data = data.filter(c => c.type === 'spot');
  else if (f === 'futures') data = data.filter(c => c.type === 'both');
  else if (f === 'drama') data = data.filter(c => c.drama).sort((a,b) => Math.abs(b.change24) - Math.abs(a.change24));
  else if (f === 'gainer') data = data.filter(c => c.change24 > 0).sort((a,b) => b.change24 - a.change24);
  else if (f === 'loser') data = data.filter(c => c.change24 < 0).sort((a,b) => a.change24 - b.change24);
  else if (f === 'defi') data = data.filter(c => c.cats.includes('defi'));
  else if (f === 'ai') data = data.filter(c => c.cats.includes('ai'));
  else if (f === 'l2') data = data.filter(c => c.cats.includes('l2'));
  else if (f === 'meme') data = data.filter(c => c.cats.includes('meme'));

  const tbody = document.getElementById('market-tbody');
  if (!data.length) {
    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--text3);padding:2rem;font-family:var(--mono);">Không có dữ liệu</td></tr>';
    return;
  }

  tbody.innerHTML = data.slice(0, 80).map(c => {
    const chg24 = c.change24 ? c.change24.toFixed(2) : '0.00';
    const chg7d = c.change7d ? c.change7d.toFixed(2) : '0.00';
    const cls24 = parseFloat(chg24) >= 0 ? 'up' : 'down';
    const cls7d = parseFloat(chg7d) >= 0 ? 'up' : 'down';
    const sign24 = parseFloat(chg24) >= 0 ? '+' : '';
    const sign7d = parseFloat(chg7d) >= 0 ? '+' : '';
    const vol = formatVol(c.volume);

    const typeBadges = c.type === 'both'
      ? '<span class="badge spot">SPOT</span> <span class="badge futures">FUT</span>'
      : '<span class="badge spot">SPOT</span>';

    const catBadges = c.cats.slice(0,1).map(cat => {
      const colors = { defi:'blue', ai:'airdrop', l2:'futures', meme:'drama', rwa:'narrative', gaming:'trend' };
      return `<span class="badge ${colors[cat]||'spot'}" style="font-size:8px;">${cat.toUpperCase()}</span>`;
    }).join('');

    const trendBadge = c.trending ? '<span class="badge trend" style="font-size:8px;">🔥 HOT</span>' : '';

    return `<tr onclick="selectCoinForPost('${c.symbol}')" style="cursor:pointer;">
      <td>
        <span class="coin-name">#${c.rank} $${c.symbol}</span><br/>
        <span class="coin-tag">${c.name}</span>
      </td>
      <td>${typeBadges}<br/>${catBadges} ${trendBadge}</td>
      <td style="font-family:var(--mono);">$${formatPrice(c.price)}</td>
      <td class="${cls24}" style="font-family:var(--mono);font-weight:600;">${sign24}${chg24}%</td>
      <td class="${cls7d}" style="font-family:var(--mono);">${sign7d}${chg7d}%</td>
      <td style="font-family:var(--mono);color:var(--text2);">$${vol}</td>
      <td style="font-size:11px;">${c.signal}</td>
    </tr>`;
  }).join('');
}

