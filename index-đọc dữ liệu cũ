  const secret = document.getElementById('binance-secret').value.trim();

  if (!apiKey || !secret) {
    addLog('warn', '⚠ Không có Binance API key — Bài viết đã sẵn sàng để copy thủ công.');
    return { success: true, postId: 'MANUAL_' + Date.now(), simulated: true };
  }

  const timestamp = Date.now();
  const payload = { content, timestamp };
  addLog('warn', `[BINANCE SQUARE API] Payload ready. Cần backend để ký HMAC SHA256.`);
  addLog('warn', `⚠ Binance Square Creator API yêu cầu Apply qua Creator Program.`);
  return { success: true, postId: 'PENDING_' + timestamp, simulated: true };
}

// ═══════════════════════════════════════════
//  MAIN CYCLE
// ═══════════════════════════════════════════
async function runCycle(postFlag = true) {
  addLog('info', '── Bắt đầu chu kỳ mới ──');

  if (!state.marketData.length) {
    addLog('info', 'Chưa có dữ liệu, đang quét...');
    await fetchMarket();
  }

  if (!state.marketData.length) {
    addLog('err', 'Không thể lấy dữ liệu thị trường');
    return;
  }

  const topic = pickTopicForPost();
  const { type, coin, preItem, narrative } = topic;

  const label = type === 'pre-listing' ? `$${preItem.symbol} [Pre-listing]`
    : type === 'narrative' ? `${narrative.name} / $${coin?.symbol}`
    : `$${coin?.symbol} [${type}]`;

  addLog('info', `Chọn topic: ${label}`);
  addLog('info', `Gọi GPT-4o để tạo bài...`);

  let content;
  try {
    content = await generatePost(coin, type, preItem, narrative);
    addLog('ok', `✓ Bài viết tạo xong (${content.length} ký tự)`);
  } catch(e) {
    addLog('err', 'Lỗi OpenAI: ' + e.message);
    return;
  }

  const displayCoin = coin || (preItem ? { symbol: preItem.symbol, name: preItem.name, change24: 0 } : { symbol: '?', name: '?', change24: 0 });
  showPreview(content, displayCoin, type);

  if (postFlag) {
    try {
      const res = await postToBinance(content, displayCoin);
      if (res.success) {
        state.posted++;
        document.getElementById('m-posted').textContent = state.posted;
        addLog('ok', `✓ Bài #${state.posted} sẵn sàng — ID: ${res.postId}${res.simulated ? ' [COPY/MANUAL]' : ''}`);
        addToHistory(content, displayCoin, type, res.postId);
      }
    } catch(e) {
      addLog('err', 'Lỗi: ' + e.message);
    }
  }
}

// ═══════════════════════════════════════════
//  UI HELPERS
// ═══════════════════════════════════════════
function showPreview(content, coin, type) {
  const typeColors = {
    'spot': 'var(--blue)',
    'futures': 'var(--purple)',
    'narrative': 'var(--green)',
    'pre-listing': 'var(--orange)',
    'airdrop': 'var(--teal)',
  };
  const typeLabels = {
    'spot': 'SPOT', 'futures': 'FUTURES', 'narrative': 'NARRATIVE',
    'pre-listing': 'PRE-LISTING', 'airdrop': 'AIRDROP',
  };
  const color = typeColors[type] || 'var(--accent)';
  const label = typeLabels[type] || type.toUpperCase();

  const charCount = content.length;
  const wordCount = content.split(/\s+/).filter(Boolean).length;

  const html = `
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
      <div style="display:flex;gap:8px;align-items:center;">
        <span style="font-family:var(--mono);font-size:10px;padding:2px 8px;border-radius:4px;background:rgba(0,0,0,0.3);color:${color};border:1px solid ${color}40;">${label}</span>
        <span style="font-family:var(--mono);font-size:11px;color:var(--accent);">$${coin.symbol}</span>
        <span style="font-family:var(--mono);font-size:10px;color:var(--text3);">${new Date().toLocaleString('vi-VN')}</span>
      </div>
      <div style="display:flex;gap:6px;">
        <span style="font-family:var(--mono);font-size:10px;color:var(--text3);">${wordCount} words · ${charCount} chars</span>
        <button class="btn copy-btn" onclick="copyContent()">📋 Copy</button>
      </div>
    </div>
    <div class="post-card" id="preview-post-card">
      <div class="post-body" id="preview-post-body">${escHtml(content)}</div>
    </div>`;

  document.getElementById('preview-empty').style.display = 'none';
  document.getElementById('preview-content').style.display = 'block';
  document.getElementById('preview-content').innerHTML = html;
  switchTab('preview');

  // Store content for copy
  window._lastPreviewContent = content;
}

function copyContent() {
  if (window._lastPreviewContent) {
    navigator.clipboard.writeText(window._lastPreviewContent).then(() => {
      addLog('ok', '✓ Đã copy bài viết vào clipboard!');
    }).catch(() => {
      addLog('warn', 'Copy thất bại, hãy copy thủ công.');
    });
  }
}

function addToHistory(content, coin, type, postId) {
  const el = document.getElementById('history-list');
  if (el.querySelector('[data-empty]')) el.innerHTML = '';

  const item = document.createElement('div');
  item.className = 'post-card';
  item.style.marginBottom = '12px';
  const typeLabels = { spot:'SPOT', futures:'FUTURES', narrative:'NARRATIVE', 'pre-listing':'PRE-LISTING' };
  item.innerHTML = `
    <div class="post-meta">
      <span class="badge ${type === 'narrative' ? 'trend' : type === 'pre-listing' ? 'pre-listing' : type === 'futures' ? 'futures' : 'spot'}">${typeLabels[type]||type}</span>
      <span class="badge off-chain">$${coin.symbol}</span>
      <span class="post-time">${new Date().toLocaleString('vi-VN')} — ${postId}</span>
      <button class="btn copy-btn" onclick="navigator.clipboard.writeText(${JSON.stringify(content)});addLog('ok','Copied!')">📋 Copy</button>
    </div>
    <div class="post-body" style="max-height:80px;overflow:hidden;">${escHtml(content.substring(0,250))}${content.length>250?'..':''}</div>`;
  el.prepend(item);
}

function addLog(type, msg) {
  const wrap = document.getElementById('log-wrap');
  const ts = new Date().toLocaleTimeString('vi-VN');
  const cls = { ok:'log-ok', err:'log-err', info:'log-info', warn:'log-warn' }[type] || 'log-info';
  const line = document.createElement('div');
  line.className = 'log-line';
  line.innerHTML = `<span class="log-ts">${ts}</span><span class="${cls}">${escHtml(msg)}</span>`;
  wrap.appendChild(line);
  wrap.scrollTop = wrap.scrollHeight;
}

function clearLog() { document.getElementById('log-wrap').innerHTML = ''; }

function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function switchTab(name) {
  const names = ['market','trends','prelisting','sources','preview','log','history'];
  document.querySelectorAll('.tab').forEach((t, i) => t.classList.toggle('active', names[i] === name));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.toggle('active', p.id === 'tab-' + name));
}

function formatPrice(p) {
  if (!p) return '0';
  if (p > 1000) return p.toLocaleString('en-US', {maximumFractionDigits: 0});
  if (p > 1) return p.toFixed(2);
  return p.toFixed(6);
}
function formatVol(v) {
  if (!v) return '0';
  if (v > 1e9) return (v/1e9).toFixed(2)+'B';
  if (v > 1e6) return (v/1e6).toFixed(1)+'M';
  if (v > 1e3) return (v/1e3).toFixed(0)+'K';
  return String(v);
}

// ═══════════════════════════════════════════
//  COUNTDOWN
// ═══════════════════════════════════════════
function startCountdown() {
  if (state.countdownTimer) clearInterval(state.countdownTimer);
  state.countdownTimer = setInterval(() => {
    if (!state.nextRun) return;
    const diff = state.nextRun - Date.now();
    if (diff <= 0) { document.getElementById('m-countdown').textContent = '00:00'; return; }
    const m = Math.floor(diff/60000).toString().padStart(2,'0');
    const s = Math.floor((diff%60000)/1000).toString().padStart(2,'0');
    document.getElementById('m-countdown').textContent = m + ':' + s;
    document.getElementById('next-label').textContent = 'Đăng lúc ' + new Date(state.nextRun).toLocaleTimeString('vi-VN');
  }, 1000);
}

// ═══════════════════════════════════════════
//  BOT CONTROL
// ═══════════════════════════════════════════
async function startBot() {
  state.running = true;
  document.getElementById('btn-start').disabled = true;
  document.getElementById('btn-stop').disabled = false;
  document.getElementById('status-pill').className = 'status-pill running';
  document.getElementById('status-text').textContent = 'RUNNING';
  addLog('ok', '🚀 Bot bắt đầu chạy!');

  const intervalMs = (parseInt(document.getElementById('interval').value) || 30) * 60 * 1000;

  await runCycle(true);

  state.timer = setInterval(async () => {
    if (!state.running) return;
    await runCycle(true);
    state.nextRun = Date.now() + intervalMs;
  }, intervalMs);

  state.nextRun = Date.now() + intervalMs;
  startCountdown();
}

function stopBot() {
  state.running = false;
  if (state.timer) clearInterval(state.timer);
  if (state.countdownTimer) clearInterval(state.countdownTimer);
  state.nextRun = null;
  document.getElementById('btn-start').disabled = false;
  document.getElementById('btn-stop').disabled = true;
  document.getElementById('status-pill').className = 'status-pill';
  document.getElementById('status-text').textContent = 'STOPPED';
  document.getElementById('m-countdown').textContent = '—';
  document.getElementById('next-label').textContent = '—';
  addLog('warn', '■ Bot đã dừng.');
}

async function runOnce() {
  addLog('info', 'Chạy thủ công 1 lần...');
  await runCycle(true);
}

async function previewOnly() {
  addLog('info', 'Preview mode...');
  if (!state.marketData.length) await fetchMarket();
  if (!state.marketData.length) { addLog('err', 'Không có dữ liệu'); return; }
  const { type, coin, preItem, narrative } = pickTopicForPost();
  try {
    const content = await generatePost(coin, type, preItem, narrative);
    const displayCoin = coin || (preItem ? { symbol: preItem.symbol, name: preItem.name, change24: 0 } : { symbol: '?', name: '?', change24: 0 });
    showPreview(content, displayCoin, type);
    addLog('ok', `Preview: ${type} ${displayCoin.symbol}`);
  } catch(e) {
    addLog('err', e.message);
  }
}

async function previewOnlyCoin(coin, type) {
  try {
    const content = await generatePost(coin, type, null, null);
    showPreview(content, coin, type);
    addLog('ok', `Preview $${coin.symbol} xong`);
  } catch(e) {
    addLog('err', e.message);
  }
}

