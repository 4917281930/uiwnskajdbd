const spotR = document.getElementById('pct-spot-range');
const futR = document.getElementById('pct-futures-range');
const trendR = document.getElementById('pct-trend-range');

function updateRatios() {
  let s = parseInt(spotR.value);
  let f = parseInt(futR.value);
  let t = parseInt(trendR.value);
  let total = s + f + t;
  if (total > 80) {
    const excess = total - 80;
    t = Math.max(0, t - excess);
    trendR.value = t;
    total = s + f + t;
  }
  let a = Math.max(0, 100 - s - f - t);
  document.getElementById('pct-spot').textContent = s + '%';
  document.getElementById('pct-futures').textContent = f + '%';
  document.getElementById('pct-trend').textContent = t + '%';
  document.getElementById('pct-airdrop').textContent = a + '%';
  document.getElementById('rs-spot').style.width = s + '%';
  document.getElementById('rs-fut').style.width = f + '%';
  document.getElementById('rs-trend').style.width = t + '%';
  document.getElementById('rs-air').style.width = a + '%';
}
spotR.oninput = updateRatios;
futR.oninput = updateRatios;
trendR.oninput = updateRatios;

